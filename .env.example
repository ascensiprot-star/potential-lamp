# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/truvornex_db

# Security Secrets
SESSION_SECRET=your_session_secret_here
TRUST_PASSPORT_SECRET=your_trust_passport_secret_here
SIMON_SYSTEM_TOKEN=your_simon_system_token_here
MFA_ENCRYPTION_KEY=your_mfa_encryption_key_here

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here

# AI Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Environment
NODE_ENV=development

# Server Configuration
PORT=5000

# Payment Gateway (Optional)
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# Third-party Auth (Optional)
CLERK_SECRET_KEY=your_clerk_secret_key_here
AUTH0_SECRET=your_auth0_secret_here
